PORT=4000
NODE_ENV=development

# Database — use EITHER DATABASE_URL or individual vars
DATABASE_URL=postgres://user:pass@localhost:5432/recycle_db
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=recycle_db
# DB_USER=user
# DB_PASSWORD=pass
DB_SSL=false

# JWT
JWT_SECRET=replace_with_strong_secret
JWT_REFRESH_SECRET=replace_with_refresh_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# File uploads
UPLOAD_DIR=./uploads